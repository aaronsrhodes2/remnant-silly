# Local tooling
.claude/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Logs & scratch
*.log
*.tmp
.scratch*

# Stray generated images / avatars
*.jpg
*.jpeg
*.png

# ...but extension/assets is our curated, pre-generated world art — keep it all
!extension/assets/**

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Secrets (defense in depth — none exist today, but guard future)
.env
.env.*
!.env.example
*.key
*.pem
secrets.json
credentials.json

# Large model artifacts (defense in depth — these live inside Docker
# image layers, not the repo, but guard against anyone ever caching
# weights into the working tree by accident)
*.safetensors
*.gguf
*.ckpt
*.pth
*.pt
*.onnx
*.bin
.cache/
huggingface/
models/
!docker/**/models/
