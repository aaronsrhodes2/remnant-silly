# Local tooling
.claude/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Logs & scratch
*.log
*.tmp
.scratch*

# ---------------------------------------------------------------------------
# Image policy
# ---------------------------------------------------------------------------
# Default-deny all image files anywhere in the repo to keep stray renders,
# screenshots, and generated scene captures from bloating history.
*.jpg
*.jpeg
*.png
*.gif
*.webp

# ...but permit images in our *curated asset directories*. These are the
# only places an image may live and still ship with the repo. Everything
# else is treated as runtime scratch and stays ignored.
#
# Canonical asset locations:
#   extension/assets/**                            — extension's world art
#   docker/sillytavern/content/**/assets/**        — SillyTavern seed assets
#                                                    (world info portraits,
#                                                    background art, etc.)
#   docker/sillytavern/content/characters/**       — character card PNGs
#                                                    (format is "PNG with
#                                                    JSON in tEXt chunks",
#                                                    so the file IS the card)
!extension/assets/**
!docker/sillytavern/content/**/assets/**
!docker/sillytavern/content/characters/**

# ---------------------------------------------------------------------------
# SillyTavern content tree
# ---------------------------------------------------------------------------
# docker/sillytavern/content/ is the canonical ST seed tree baked into the
# sillytavern image at build time. **Default-permit the whole tree** — every
# non-image, non-junk file under it ships. A clean `git clone && docker
# compose up` must reproduce this tree bit-for-bit, so curate via explicit
# ignore rules below rather than a hand-picked Dockerfile COPY list.
#
# Image policy inside content/: the global *.png/*.jpg/etc deny above still
# applies here — images may ONLY live under content/**/assets/** or
# content/characters/** (already re-permitted up in the image section).
# Everything else under content/ (json, jsonl, yaml, etc.) ships freely.
!docker/sillytavern/content/**/*.json
!docker/sillytavern/content/**/*.jsonl
!docker/sillytavern/content/**/*.yaml
!docker/sillytavern/content/**/*.yml
!docker/sillytavern/content/**/*.txt
!docker/sillytavern/content/**/*.md
!docker/sillytavern/content/**/*.html
!docker/sillytavern/content/**/*.css
!docker/sillytavern/content/**/*.js
!docker/sillytavern/content/**/*.svg

# Junk + sensitive patterns that must NEVER land in the shipped image,
# even if they appear in the native ST data dir we mirror from:
docker/sillytavern/content/**/*.bak*
docker/sillytavern/content/**/_disabled_*

# Credentials: the real settings.json under default-user/ carries API keys
# and persona descriptions. Block every nested settings.json; permit ONLY
# the single curated, credential-free top-level seed at the content-tree
# root (a minimal Ollama-wired config).
docker/sillytavern/content/**/settings.json
!docker/sillytavern/content/settings.json
docker/sillytavern/content/**/secrets.json
docker/sillytavern/content/**/stats.json

# Runtime state directories — never shipped, regenerated by ST at boot.
docker/sillytavern/content/backups/
docker/sillytavern/content/thumbnails/
docker/sillytavern/content/vectors/
docker/sillytavern/content/User\ Avatars/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Secrets (defense in depth — none exist today, but guard future)
.env
.env.*
!.env.example
*.key
*.pem
secrets.json
credentials.json

# Large model artifacts (defense in depth — these live inside Docker
# image layers, not the repo, but guard against anyone ever caching
# weights into the working tree by accident)
*.safetensors
*.gguf
*.ckpt
*.pth
*.pt
*.onnx
*.bin
.cache/
huggingface/
models/
!docker/**/models/

# Dev cache — bind-mount target for docker-compose.dev.yml. Holds
# nginx's upstream proxy cache (HuggingFace weights, pip wheels,
# ollama.com static files — everything nginx librarians) plus the
# ollama model store (the hybrid-exception upstream). The nested
# dev-cache/.gitignore is the primary guard; this is belt-and-
# suspenders.
dev-cache/hf-cache/**
dev-cache/nginx-cache/**
dev-cache/ollama-data/**
!dev-cache/hf-cache/.gitkeep
!dev-cache/nginx-cache/.gitkeep
!dev-cache/ollama-data/.gitkeep

# Native dev runtime staging — PID files, logs, etc. written by
# scripts/native-up.sh. The status/*.json files in the same dir are
# tracked (they're the native mirror of the remnant-status volume).
scripts/splash/status/.native-run/
