# The Remnant Fortress — environment configuration
#
# Copy this file to `.env` to override defaults:
#   cp .env.example .env
#
# Every value is optional. There are ZERO credentials or API keys — this
# stack runs entirely locally against Ollama and Stable Diffusion.

# Host port to expose SillyTavern on. Default 8001.
HOST_PORT=8001

# Which Ollama model to auto-pull on first boot. Default: mistral (7B, ~4 GB)
#
# VRAM budget guidance (assuming Stable Diffusion also runs on the same GPU):
#   8 GB card  → mistral, phi3, gemma:2b  (keep Ollama on CPU in compose)
#   12 GB card → mistral, llama3.1:8b, mistral-nemo
#   16 GB card → mistral, llama3.1:8b, mistral-nemo, qwen2.5:14b (tight)
#   24 GB card → add mixtral (~26 GB needs partial CPU offload) or llama3.1:70b-q4
#
# See https://ollama.com/library for the full model catalog.
OLLAMA_MODEL=mistral

# ---------------------------------------------------------------------------
# Warm-test host cache paths (docker-compose.warm.yml only)
# ---------------------------------------------------------------------------
#
# The warm test skips the ~20 GB first-boot download by rebinding the
# hf-cache and ollama-data volumes directly to the developer's existing
# host caches. Set these to the absolute path of the matching host
# directory on your machine. Docker Desktop on Windows accepts the
# forward-slash style (C:/Users/you/...).
#
# Only used when you run:
#   docker compose -f docker-compose.yml -f docker-compose.warm.yml up
#
# Defaults are placeholders — override in your .env to match your host.
HOST_HF_HOME=C:/Users/you/.cache/huggingface
HOST_OLLAMA_DIR=C:/Users/you/.ollama
